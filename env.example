# RoadSOS - Mobile Client Environment Variables Configuration
# Copy this file to `.env` and fill in your actual credentials.

# ==========================================
# 🤖 AI & Generative Services
# ==========================================
# Google Gemini API Key - https://aistudio.google.com/
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ==========================================
# 📍 Maps & Location intelligence APIs
# ==========================================
# Google Maps API Key - Requires Directions, Places, and Maps SDKs enabled - https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Mapbox Access Token - https://account.mapbox.com/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_ACCESS_TOKEN_HERE

# Geoapify API Key - https://myprojects.geoapify.com/
EXPO_PUBLIC_GEOAPIFY_API_KEY=YOUR_GEOAPIFY_API_KEY_HERE

# OpenRouteService API Key - https://openrouteservice.org/dev/#/home
EXPO_PUBLIC_OPENROUTESERVICE_API_KEY=YOUR_OPENROUTESERVICE_API_KEY_HERE

# MapTiler API Key - Free 100k tiles/month (for offline map rendering) - https://cloud.maptiler.com/account/keys
EXPO_PUBLIC_MAPTILER_KEY=YOUR_MAPTILER_KEY_HERE

# ==========================================
# 🖥️ Telemetry Backend Integration
# ==========================================
# Backend Server Endpoint (use local network IP for real device testing, e.g., http://192.168.1.XX:5000)
EXPO_PUBLIC_SERVER_URL=http://localhost:5000

# ==========================================
# 🔥 Firebase Web Client Configurations
# ==========================================
# Get these credentials from Firebase Console > Project Settings > General > Your Apps (Web App)
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your-app-id-default-rtdb.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-app-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID_HERE
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID_HERE
