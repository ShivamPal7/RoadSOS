{
  "expo": {
    "name": "RoadSOS",
    "slug": "RoadSOS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "scheme": "roadsos",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSContactsUsageDescription": "RoadSOS needs access to your contacts to import emergency contacts for SOS alerts.",
        "UIBackgroundModes": [
          "fetch",
          "location"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SEND_SMS",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.WRITE_CONTACTS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBNUT5OpWwDCpDe4oJvCENp7u_apXEg5QM"
        }
      },
      "package": "com.anonymous.RoadSOS"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Opener-Policy": "same-origin",
            "Cross-Origin-Embedder-Policy": "require-corp"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "RoadSOS needs access to your photos to attach accident scene images to reports.",
          "cameraPermission": "RoadSOS needs camera access to capture accident scene photos for AI analysis."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RoadSOS needs your location to find nearby emergency services and send your GPS coordinates in SOS alerts.",
          "locationWhenInUsePermission": "RoadSOS needs your location to find nearby emergency services and send your GPS coordinates in SOS alerts."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "RoadSOS needs access to your contacts to import emergency contacts for SOS alerts."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#d90429",
          "defaultChannel": "emergency"
        }
      ],
      "@maplibre/maplibre-react-native"
    ]
  }
}
